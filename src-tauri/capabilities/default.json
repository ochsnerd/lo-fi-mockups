{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    { "identifier": "fs:scope", "allow": [{ "path": "**" }] },
    "cli:default",
    "dialog:default",
    "log:default"
  ]
}
